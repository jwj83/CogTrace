# Copy this file to .env on the execution host. Never commit the copy.
# The current API gateway is OpenAI-compatible.
COGTRACE_EXTRACTOR_BASE_URL=https://uni-api.cstcloud.cn/v1
COGTRACE_EXTRACTOR_MODEL=deepseek-v4-flash
COGTRACE_EXTRACTOR_API_KEY=

# Run the first collection in shadow mode: state is recorded but never blocks Agent actions.
COGTRACE_MODE=shadow
COGTRACE_CONTEXT_PROFILE=deepseek-512k
